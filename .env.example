# ============================================================================
# 3D Printer Slicer API - .env example
# ============================================================================
# Copy this file as .env and adjust values as needed.

# ------------------------------
# Required settings
# ------------------------------
# API key used for admin-protected endpoints.
ADMIN_API_KEY=exampleKEY-6.7.


# ------------------------------
# Optional settings
# ------------------------------

# ------------------------------
# Body / Upload limits
# ------------------------------
# Express JSON body limit (e.g. 1mb, 5mb)
JSON_BODY_LIMIT=1mb

# Express URL-encoded/form body limit (e.g. 1mb, 5mb)
FORM_BODY_LIMIT=1mb

# Max upload file size in bytes (multipart)
# Example: 500 MB = 524288000 (500 * 1024 * 1024))
MAX_UPLOAD_BYTES=524288000

# ------------------------------
# Rate limiting
# ------------------------------
# Rate limit time window in ms
SLICE_RATE_LIMIT_WINDOW_MS=60000

# Number of allowed requests per IP in the time window
SLICE_RATE_LIMIT_MAX_REQUESTS=3

# ------------------------------
# Queue settings
# ------------------------------
# Maximum number of slice jobs running in parallel
MAX_CONCURRENT_SLICES=1

# Maximum queue length
MAX_SLICE_QUEUE_LENGTH=100

# How long a request can wait in queue (ms)
MAX_SLICE_QUEUE_WAIT_MS=300000

# ------------------------------
# ZIP guard
# ------------------------------
# Maximum number of entries allowed in ZIP input
MAX_ZIP_ENTRIES=100

# Maximum total extracted ZIP size in bytes
# Example: 500 MB = 524288000 (500 * 1024 * 1024)
MAX_ZIP_UNCOMPRESSED_BYTES=524288000

# ------------------------------
# Slice command runtime
# ------------------------------
# External command timeout in ms (Prusa/Orca + converters)
# Example: 10 minutes = 600000
SLICE_COMMAND_TIMEOUT_MS=600000

# Enable verbose command logs (true/false)
DEBUG_COMMAND_LOGS=false

# ------------------------------
# Orca profile overrides
# ------------------------------
# Machine profile filename (from configs/orca)
ORCA_MACHINE_PROFILE=Bambu_P1S_0.4_nozzle.json

# Process profile filenames by layerHeight (from configs/orca)
ORCA_PROCESS_PROFILE_0_1=FDM_0.1mm.json
ORCA_PROCESS_PROFILE_0_2=FDM_0.2mm.json
ORCA_PROCESS_PROFILE_0_3=FDM_0.3mm.json

# ------------------------------
# Test scripts
# ------------------------------
# Base URL used by Python test runners
SLICER_BASE_URL=http://127.0.0.1:3000
